{
  "name": "ctp-upscaling-workshop-series",
  "private": true,
  "version": "0.1.0",
  "description": "Workshop series for CTP at NYUAD: a reusable Slidev template plus one deck per workshop.",
  "scripts": {
    "new-workshop": "node scripts/new-workshop.mjs",
    "dev:01": "pnpm --filter ./workshops/01-slidev dev",
    "build:01": "pnpm --filter ./workshops/01-slidev build",
    "export:01": "pnpm --filter ./workshops/01-slidev export",
    "export:01:pptx": "pnpm --filter ./workshops/01-slidev export:pptx",
    "build:site": "node scripts/ci-build.mjs --mode pages",
    "preview:site": "node scripts/ci-build.mjs --mode pages --no-pdf --no-pptx",
    "build:release": "node scripts/ci-build.mjs --mode release"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright-chromium": "^1.49.0"
  }
}
